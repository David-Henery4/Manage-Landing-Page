---
import CTAPillGraphic from "/public/images/bg-simplify-section-mobile.svg";
import CTAPillGraphicLarge from "/public/images/bg-simplify-section-desktop.svg";
---

<section class="bleed-section-columns cta-container main-layout-grid">
  <div class="cta-content-container inner-section-columns">
    <h2>Simplify how your team works today.</h2>
    <button class="cta-button cta-button-secondary">Get Started</button>
  </div>
  <div class="cta-bg-pill-mobile">
    <CTAPillGraphic class="svg-resize-full" />
  </div>
  <div class="cta-bg-pill-large">
    <CTAPillGraphicLarge class="svg-resize-full" />
  </div>
</section>
